{
  "name": "ayden-blog-backend",
  "version": "1.0.0",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && refine build",
    "dev": "concurrently \"refine dev --host\" \"pnpm --filter ./server run start:dev\"",
    "refine": "refine",
    "start": "refine start",
    "lint": "eslint --fix"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.8.2",
    "@emotion/styled": "^11.8.1",
    "@mui/icons-material": "^6.5.0",
    "@mui/lab": "^6.0.0-beta.14",
    "@mui/material": "^6.1.7",
    "@mui/utils": "^6.1.6",
    "@mui/x-data-grid": "^8.24.0",
    "@mui/x-date-pickers": "^7.23.3",
    "@mui/x-date-pickers-pro": "^7.23.3",
    "@refinedev/cli": "^2.16.52",
    "@refinedev/core": "^5.0.11",
    "@refinedev/devtools": "^2.0.5",
    "@refinedev/mui": "^8.0.0",
    "@refinedev/nestjsx-crud": "^6.0.1",
    "@refinedev/react-hook-form": "^5.0.4",
    "@refinedev/react-router": "^2.0.4",
    "@refinedev/rest": "^2.1.1",
    "@tanstack/react-query": "^5.81.5",
    "better-auth": "^1.5.5",
    "dayjs": "^1.10.7",
    "ky": "^1.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.57.0",
    "react-hot-toast": "^2.4.1",
    "react-infinite-scroll-component": "^6.1.0",
    "react-router": "^7.0.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.1.0",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-refresh": "^0.5.2",
    "typescript": "^5.8.3",
